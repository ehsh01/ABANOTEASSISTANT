# PostgreSQL (DigitalOcean managed database)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Required for JWT auth (use a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated emails that receive super_admin on first registration (bootstrap only).
# After bootstrap, prefer promoting users in the database: UPDATE users SET role = 'super_admin' WHERE email = '...';
SUPER_ADMIN_EMAILS=

# When true, POST /notes/generate requires companies.free_usage = true (complimentary flag).
# Leave unset/false until billing is ready.
# ENFORCE_COMPLIMENTARY_ACCESS=false

# --- Session note generation (OpenAI) ---
# Required for GPT-powered clinical narrative between the fixed opening/closing blocks.
# Without it, POST /notes/generate uses the built-in template and returns a warning.
# OPENAI_API_KEY=sk-...
# Optional override (default: gpt-5.3-chat-latest).
# OPENAI_MODEL=gpt-5.3-chat-latest

# --- Email verification (Resend) ---
# In production, registration requires Resend unless EMAIL_VERIFICATION_DISABLED=true.
# RESEND_API_KEY=re_xxxx
# Sender shown in the inbox (must be allowed in Resend for your domain).
# EMAIL_FROM="ABA Note Assistant <onboarding@resend.dev>"
# Public origin of the SPA (no trailing slash). Used in confirmation links.
# APP_ORIGIN=https://your-app.example.com
# If the app is served under a subpath, set it without trailing slash (e.g. /abanote).
# APP_BASE_PATH=

# Skip sending verification emails and sign users in immediately (local dev only).
# EMAIL_VERIFICATION_DISABLED=false
