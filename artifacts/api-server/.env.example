# SPA: when the React app and API are not same-origin, set VITE_API_BASE_URL at SPA build time
# (see artifacts/abanoteassistant/.env.example). Nginx same-host /api proxy needs no VITE_*.

# PostgreSQL (DigitalOcean managed database)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Max pooled connections for THIS process (default 4). The managed cluster caps total
# connections (smallest DO tier: 25, 3 reserved for superuser) and is shared by several
# apps on the droplet — keep this low to avoid "remaining connection slots are reserved"
# (SQLSTATE 53300) errors across apps. Production + staging each get their own pool.
# PG_POOL_MAX=4

# Optional: separate DB for PM2 app `abanoteassistant-api-staging` (port 5007 by default).
# Must live in THIS file — `artifacts/api-server/ecosystem.config.cjs` reads it at PM2 start.
# If unset, staging falls back to DATABASE_URL (same data as production).
# DATABASE_URL_STAGING=postgresql://user:password@host:5432/staging_db?sslmode=require

# Optional: separate JWT secret for staging (if unset, uses JWT_SECRET).
# JWT_SECRET_STAGING=

# Required for JWT auth (use a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated emails that receive super_admin on first registration (bootstrap only).
# After bootstrap, prefer promoting users in the database: UPDATE users SET role = 'super_admin' WHERE email = '...';
SUPER_ADMIN_EMAILS=

# When true, POST /notes/generate requires companies.free_usage = true (complimentary flag).
# Leave unset/false until billing is ready.
# ENFORCE_COMPLIMENTARY_ACCESS=false

# --- Stripe billing (optional; legacy install works without any of these) ---
# When STRIPE_SECRET_KEY is unset, every /billing/* route returns 503 and BILLING_ENFORCEMENT
# is forced to `off` — POST /notes/generate and /notes/{id}/save behave exactly like before.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...    # set after creating the endpoint in Stripe dashboard
# STRIPE_PRICE_STARTER=price_...     # monthly recurring price IDs from Stripe → Products
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_HIGH=price_...
# STRIPE_TRIAL_DAYS=14               # app-managed trial length for new registrations (0 = none)
# STRIPE_TRIAL_NOTE_CAP=15           # max notes a trial may save (0 = uncapped). Trial ends on whichever comes first.
# BILLING_GRACE_PERIOD_DAYS=7        # how long past_due continues to allow note saves
# BILLING_ENFORCEMENT=off            # off | soft | hard  (off keeps legacy behavior)
# MAX_UNSAVED_DRAFTS=3               # per-user cap on generated-but-unsaved notes (1..100, default 3)

# --- Session note generation (OpenAI) ---
# POST /notes/generate always uses OpenAI for the clinical body. No template fallback.
# Without OPENAI_API_KEY the API returns 503; if OpenAI errors, returns 502.
# Local dev: `pnpm dev` loads this file via src/load-local-env.ts (NODE_ENV=development).
# Production/staging: PM2 ecosystem.config.cjs loads this file into the process.
# Use KEY=value only (do not prefix with `export `). Save as UTF-8 without a BOM if your editor offers the choice.
# OPENAI_API_KEY=sk-...
# Optional: set on the server (no code change) so GET /api/healthz shows which deploy is running.
# API_BUILD_ID=abc1234

# Optional override (default: gpt-4.1 until further notice).
# OPENAI_MODEL=gpt-4.1
# Optional: gpt-5 family reasoning effort for note NotePlan JSON (default: medium).
# Use low to prioritize latency; high for hardest multi-hour cases. Other values omit the param.
# OPENAI_REASONING_EFFORT=medium
# Optional: fallback model when the primary times out / 429 / 5xx (default: gpt-5.5 while primary is gpt-4.1).
# Set to none/off/disabled to disable fallback.
# OPENAI_FALLBACK_MODEL=gpt-5.5
# Optional: model for POST /clients/assessment/extract (defaults to OPENAI_MODEL, then gpt-4.1).
# Prefer a cheaper extract model in prod when extract quality is acceptable.
# OPENAI_ASSESSMENT_EXTRACT_MODEL=gpt-4o
# Optional: per-request OpenAI timeout in ms for sync POST /notes/generate (default 60000).
# OPENAI_REQUEST_TIMEOUT_MS=60000
# Optional: overall wall-clock budget in ms for the sync generate+repair loop (default 80000). Kept under
# Cloudflare's ~100s origin timeout so the synchronous endpoint returns a clean JSON error
# instead of a raw 524 when compliance repairs cannot converge in time.
# NOTE_GENERATION_TIME_BUDGET_MS=80000
# Background (async job) path — UI uses POST /notes/generate/jobs. Larger defaults so medium
# reasoning + repairs can finish without Cloudflare cutting the request.
# OPENAI_BACKGROUND_REQUEST_TIMEOUT_MS=180000
# NOTE_GENERATION_BACKGROUND_TIME_BUDGET_MS=240000

# Audit rows always retain artifact hashes, code-only validator histories/final issue arrays,
# counts, latency, and token metadata. Filenames, free-text diagnostics/warnings/repair details,
# raw model JSON, and final note text are OFF by default because they can contain clinical data.
# Enable only under an approved restricted-access retention policy; existing rows are unaffected.
# NOTE_AUDIT_STORE_CONTENT=false

# Offline `pnpm run eval:notes` never calls a model. Live eval requires BOTH the CLI --live flag
# and this explicit opt-in, in addition to OPENAI_API_KEY.
# NOTE_EVAL_LIVE=false

# --- Email verification (Resend) ---
# In production, registration requires Resend unless EMAIL_VERIFICATION_DISABLED=true.
# RESEND_API_KEY=re_xxxx
# Sender shown in the inbox (must be allowed in Resend for your domain).
# EMAIL_FROM="ABA Note Assistant <onboarding@resend.dev>"
# Public origin of the SPA (no trailing slash). Used in confirmation links.
# APP_ORIGIN=https://your-app.example.com
# If the app is served under a subpath, set it without trailing slash (e.g. /abanote).
# APP_BASE_PATH=

# Skip sending verification emails and sign users in immediately (local dev only).
# EMAIL_VERIFICATION_DISABLED=false
